{{- $features := get . "features" | default dict -}}
{{- $isContainer := get $features "container" | default false -}}
[tool_alias.node.versions]
lts = "24"

[tools]
node = "lts"
"npm:@openai/codex" = { version = "latest", package_manager = "npm", dependencies = ["node"] }
{{ if $isContainer }}
chezmoi = "latest"
neovim = "latest"
usage = "latest"
zoxide = "latest"
{{ end }}

[settings]
# 該当ツールの慣用ファイルを見ない
# .node-versionや.python-versionなど
idiomatic_version_file_enable_tools = []

# config files with these prefixes will be trusted by default
trusted_config_paths = [
    '~/github','~/fork'
]

[tasks.codespaces-sync-ssh]
alias = "cs-sync-ssh"
description = "Generate ~/.ssh/codespaces from GitHub Codespaces"
run = '''
#!/usr/bin/env bash
set -euo pipefail

OUT="$HOME/.ssh/codespaces"

{
  echo "# generated by mise"
  echo
  gh codespace list --json name |
    jq -r '.[] |
      "Host cs-" + .name + "\n" +
      "  HostName cs-" + .name + "\n" +
      "  User codespace\n" +
      "  ProxyCommand gh codespace ssh -c " + .name + " --stdio\n"
    '
} > "$OUT"

echo "Generated: $OUT"
echo

grep '^Host ' "$OUT" | sed 's/^Host /ssh /'
'''
